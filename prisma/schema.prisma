generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Ejemplo de tabla consumible por la API (`/api/v1/vehicles`).
/// Puedes renombrar o ampliar modelos y luego ejecutar `npm run db:migrate`.
model Vehicle {
  id        String   @id
  name      String
  brand     String?
  price     Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum CatalogVehicleType {
  CARRO
  CAMIONETA
}

/// Ajustes globales de la landing (cantidad de vehículos visibles, etc.).
model LandingSettings {
  id                 String   @id @default("default")
  maxVisibleVehicles Int      @default(10)
  content            Json?
  updatedAt          DateTime @updatedAt
}

/// Historial de cambios en el panel admin de la landing.
model LandingAuditLog {
  id         String   @id
  actorEmail String
  action     String
  summary    String
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([actorEmail])
}

/// Vehículos del catálogo mostrados en la landing.
model CatalogVehicle {
  id             String               @id
  slug           String               @unique
  name           String
  subtitle       String
  type           CatalogVehicleType
  highlights     Json
  features       Json
  specs          Json
  badge          String?
  popular        Boolean              @default(false)
  weeklyPriceCop Int
  active         Boolean              @default(true)
  sortOrder      Int                  @default(0)
  specSheetPath  String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  images         CatalogVehicleImage[]
}

/// Imágenes del catálogo: archivo en disco (`storedPath`) o URL estática legacy (`publicUrl`).
model CatalogVehicleImage {
  id           String         @id
  vehicleId    String
  vehicle      CatalogVehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  storedPath   String?
  publicUrl    String?
  originalName String
  mimeType     String
  sizeBytes    Int            @default(0)
  sortOrder    Int            @default(0)
  isPrimary    Boolean        @default(false)
  createdAt    DateTime       @default(now())

  @@index([vehicleId])
}

enum UserType {
  USER
  ADVISOR
  ADMIN
  ANALYST
  WORKSHOP
}

enum DocumentValidationStatus {
  PENDING
  VALIDATED
  REJECTED
}

/// Usuarios registrados. Contraseña (bcrypt) o Google (`googleId`); al menos uno debe existir.
model User {
  id                    String                     @id
  email                 String                     @unique
  passwordHash          String?
  googleId              String?                    @unique
  userType              UserType
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
  documents             Document[]
  identityExtraction    UserIdentityExtraction?
  workAddressExtraction UserWorkAddressExtraction?
  vehiclePlan           ClientVehiclePlan?
  inspectionAppointments InspectionAppointment[] @relation("ClientInspectionAppointments")
  managedWorkshop       Workshop?
  notifications         UserNotification[]
}

/// Archivos o imágenes subidos por usuario (metadatos en BD; bytes en disco bajo uploads/).
model Document {
  id                 String                   @id
  userId             String
  user               User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  documentKind       String
  validationStatus   DocumentValidationStatus @default(PENDING)
  /// Motivo de rechazo (p. ej. verificación automática con IA).
  validationMessage  String?
  originalName       String
  mimeType           String
  sizeBytes          Int
  storedPath         String
  createdAt          DateTime                 @default(now())

  @@unique([userId, documentKind])
  @@index([userId])
}

/// Datos extraídos por IA del documento de identidad (cédula, cédula de extranjería, pasaporte, etc.) y del pase (licencia), un registro por usuario.
model UserIdentityExtraction {
  userId String @id
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Nombres de pila según el documento de identidad.
  firstName String?
  /// Apellidos según el documento de identidad.
  lastName  String?
  /// Fecha de nacimiento (YYYY-MM-DD) si se pudo leer con claridad.
  birthDate        String?
  /// Número o código del documento de identidad (p. ej. cédula, CE, pasaporte).
  idDocumentNumber String?

  /// Si el pase corresponde al mismo titular que el documento de identidad (null = aún no evaluado o datos insuficientes).
  licenseMatchesCedula Boolean?
  /// Fecha hasta la cual el pase tiene vigencia autorizada (YYYY-MM-DD cuando se pudo inferir).
  licenseValidUntil    String?

  /// Documento `Document.id` del frente de identidad validado (referencia a la foto en disco bajo `uploads/`).
  identityPhotoDocumentId String?
  /// La selfie corresponde facialmente al titular del documento de identidad.
  selfieMatchesIdentityPerson Boolean?
  /// La selfie no es la misma imagen/recorte que la foto del documento (toma distinta, p. ej. selfie real).
  selfieIsDistinctCaptureFromIdentity Boolean?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Paso 3: apps de conductor, banco y recibo de vivienda — datos validados o extraídos con IA.
model UserWorkAddressExtraction {
  userId String @id
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  utilityServiceAddress String?

  bankHolderMatchesIdentity Boolean?

  /// Ej.: {"platformWork1":{"appKey":"uber","rating":4.9}}
  platformCapturesMeta Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum InspectionAppointmentKind {
  BUSINESS_PLANNED
  CLIENT_REQUESTED
}

enum InspectionAppointmentStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  REJECTED
  COMPLETED
  CANCELLED
  RESCHEDULE_PENDING
}

enum InspectionSessionStatus {
  IN_PROGRESS
  COMPLETED
}

enum ProcedureSuggestionStatus {
  PENDING_ADMIN
  APPROVED_IMMEDIATE
  APPROVED_CLIENT_SCHEDULE
  REJECTED
}

/// Taller asociado a atoo; el usuario WORKSHOP gestiona disponibilidad y citas.
model Workshop {
  id        String   @id
  name      String
  address   String
  city      String
  phone     String?
  latitude  Float?
  longitude Float?
  active    Boolean  @default(true)
  userId    String?  @unique
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  slots     WorkshopAvailabilitySlot[]
  appointments InspectionAppointment[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Franjas de disponibilidad que el taller publica (fecha, horario y cupos).
model WorkshopAvailabilitySlot {
  id              String   @id
  workshopId      String
  workshop        Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  date            String
  startTime       String
  endTime         String
  maxAppointments Int
  bookedCount     Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([workshopId, date, startTime])
  @@index([workshopId, date])
}

/// Plan de revisión técnico-mecánica asignado al entregar el vehículo (solo lectura para el cliente).
model ClientVehiclePlan {
  userId              String   @id
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicleName         String
  vin                 String?
  deliveredAt         DateTime
  nextInspectionDueAt DateTime
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

/// Citas de revisión: planificadas por el negocio o solicitadas por el cliente.
model InspectionAppointment {
  id                String                      @id
  userId            String
  user              User                        @relation("ClientInspectionAppointments", fields: [userId], references: [id], onDelete: Cascade)
  workshopId        String
  workshop          Workshop                    @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  kind              InspectionAppointmentKind
  status            InspectionAppointmentStatus @default(PENDING)
  appointmentDate   String
  appointmentTime   String?
  proposedAppointmentDate String?
  proposedAppointmentTime String?
  rescheduleInitiatedBy   String?
  reason            String?
  proofStoredPath   String?
  proofMimeType     String?
  proofOriginalName String?
  proofSizeBytes    Int?
  workshopNotes     String?
  session           InspectionSession?
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt

  @@index([userId])
  @@index([workshopId, appointmentDate])
  @@index([workshopId, status])
}

/// Sesión de revisión iniciada por el taller durante la cita.
model InspectionSession {
  id            String                  @id
  appointmentId String                  @unique
  appointment   InspectionAppointment   @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  status        InspectionSessionStatus @default(IN_PROGRESS)
  startedAt     DateTime                @default(now())
  completedAt   DateTime?
  notes         String?
  checklistItems InspectionChecklistItem[]
  suggestions   InspectionProcedureSuggestion[]
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
}

/// Pasos estándar (y adicionales autorizados) de la revisión.
model InspectionChecklistItem {
  id          String            @id
  sessionId   String
  session     InspectionSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  title       String
  description String?
  sortOrder   Int               @default(0)
  completed   Boolean           @default(false)
  completedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([sessionId])
}

/// Procedimientos adicionales sugeridos por el taller; requieren autorización del admin.
model InspectionProcedureSuggestion {
  id               String                    @id
  sessionId        String
  session          InspectionSession         @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  title            String
  description      String?
  estimatedCostCop Int?
  isUrgent         Boolean                   @default(false)
  status           ProcedureSuggestionStatus @default(PENDING_ADMIN)
  adminNotes       String?
  reviewedAt       DateTime?
  reviewedByUserId String?
  deadlineAt       DateTime?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  @@index([sessionId])
  @@index([status])
}

/// Notificaciones in-app para clientes (reagendamientos, confirmaciones, etc.).
model UserNotification {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  message   String
  metadata  Json?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt(sort: Desc)])
}
