generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Ejemplo de tabla consumible por la API (`/api/v1/vehicles`).
/// Puedes renombrar o ampliar modelos y luego ejecutar `npm run db:migrate`.
model Vehicle {
  id        String   @id
  name      String
  brand     String?
  price     Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum CatalogVehicleType {
  CARRO
  CAMIONETA
}

/// Ajustes globales de la landing (cantidad de vehículos visibles, etc.).
model LandingSettings {
  id                 String   @id @default("default")
  maxVisibleVehicles Int      @default(10)
  content            Json?
  updatedAt          DateTime @updatedAt
}

/// Historial de cambios en el panel admin de la landing.
model LandingAuditLog {
  id         String   @id
  actorEmail String
  action     String
  summary    String
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([actorEmail])
}

/// Vehículos del catálogo mostrados en la landing.
model CatalogVehicle {
  id             String               @id
  slug           String               @unique
  name           String
  subtitle       String
  type           CatalogVehicleType
  highlights     Json
  features       Json
  specs          Json
  badge          String?
  popular        Boolean              @default(false)
  weeklyPriceCop Int
  active         Boolean              @default(true)
  sortOrder      Int                  @default(0)
  specSheetPath  String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  images         CatalogVehicleImage[]
}

/// Imágenes del catálogo: archivo en disco (`storedPath`) o URL estática legacy (`publicUrl`).
model CatalogVehicleImage {
  id           String         @id
  vehicleId    String
  vehicle      CatalogVehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  storedPath   String?
  publicUrl    String?
  originalName String
  mimeType     String
  sizeBytes    Int            @default(0)
  sortOrder    Int            @default(0)
  isPrimary    Boolean        @default(false)
  createdAt    DateTime       @default(now())

  @@index([vehicleId])
}

enum UserType {
  USER
  ADVISOR
  ADMIN
  ANALYST
}

enum DocumentValidationStatus {
  PENDING
  VALIDATED
  REJECTED
}

/// Usuarios registrados. Contraseña (bcrypt) o Google (`googleId`); al menos uno debe existir.
model User {
  id                    String                     @id
  email                 String                     @unique
  passwordHash          String?
  googleId              String?                    @unique
  userType              UserType
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
  documents             Document[]
  identityExtraction    UserIdentityExtraction?
  workAddressExtraction UserWorkAddressExtraction?
}

/// Archivos o imágenes subidos por usuario (metadatos en BD; bytes en disco bajo uploads/).
model Document {
  id                 String                   @id
  userId             String
  user               User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  documentKind       String
  validationStatus   DocumentValidationStatus @default(PENDING)
  /// Motivo de rechazo (p. ej. verificación automática con IA).
  validationMessage  String?
  originalName       String
  mimeType           String
  sizeBytes          Int
  storedPath         String
  createdAt          DateTime                 @default(now())

  @@unique([userId, documentKind])
  @@index([userId])
}

/// Datos extraídos por IA del documento de identidad (cédula, cédula de extranjería, pasaporte, etc.) y del pase (licencia), un registro por usuario.
model UserIdentityExtraction {
  userId String @id
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Nombres de pila según el documento de identidad.
  firstName String?
  /// Apellidos según el documento de identidad.
  lastName  String?
  /// Fecha de nacimiento (YYYY-MM-DD) si se pudo leer con claridad.
  birthDate        String?
  /// Número o código del documento de identidad (p. ej. cédula, CE, pasaporte).
  idDocumentNumber String?

  /// Si el pase corresponde al mismo titular que el documento de identidad (null = aún no evaluado o datos insuficientes).
  licenseMatchesCedula Boolean?
  /// Fecha hasta la cual el pase tiene vigencia autorizada (YYYY-MM-DD cuando se pudo inferir).
  licenseValidUntil    String?

  /// Documento `Document.id` del frente de identidad validado (referencia a la foto en disco bajo `uploads/`).
  identityPhotoDocumentId String?
  /// La selfie corresponde facialmente al titular del documento de identidad.
  selfieMatchesIdentityPerson Boolean?
  /// La selfie no es la misma imagen/recorte que la foto del documento (toma distinta, p. ej. selfie real).
  selfieIsDistinctCaptureFromIdentity Boolean?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Paso 3: apps de conductor, banco y recibo de vivienda — datos validados o extraídos con IA.
model UserWorkAddressExtraction {
  userId String @id
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  utilityServiceAddress String?

  bankHolderMatchesIdentity Boolean?

  /// Ej.: {"platformWork1":{"appKey":"uber","rating":4.9}}
  platformCapturesMeta Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
