PORT=4000
CLIENT_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Coste bcrypt (12 por defecto). Más alto = más seguro y más lento.
BCRYPT_ROUNDS=12

# PostgreSQL (ajusta usuario, contraseña, host y nombre de BD)
# Coincide con backend/docker-compose.yml si usas ese Postgres local
# Puerto 5433 en el Mac = contenedor Postgres (ver docker-compose.yml). Si usas otro Postgres en 5432, no choquean.
DATABASE_URL="postgresql://landing:landing@localhost:5433/landing?schema=public"

# Archivos subidos (documentos por usuario). Carpeta ignorada por git.
# UPLOAD_DIR=/ruta/absoluta/opcional
UPLOAD_MAX_BYTES=15728640
# Lista separada por comas (opcional; por defecto imágenes comunes + PDF + Word + txt)
# UPLOAD_ALLOWED_MIMES=image/jpeg,image/png,application/pdf

# Verificación automática del PDF de autorización de datos (Google Gemini — clave gratuita en AI Studio)
# https://aistudio.google.com/apikey
# GEMINI_API_KEY=

# Inicio de sesión / registro con Google (OAuth 2.0 — Google Cloud Console)
# https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=
# Modelo preferido (opcional). Si falla, el servidor prueba otros en cadena (ver código: DEFAULT_MODEL_CHAIN).
# GEMINI_MODEL=gemini-2.5-flash
# Modelos extra a probar, separados por comas, después de los por defecto:
# GEMINI_MODEL_FALLBACKS=gemini-2.5-flash-lite
# Solo desarrollo: omitir verificación por IA (no usar en producción)
# DATA_TREATMENT_SKIP_AI_VERIFY=true
